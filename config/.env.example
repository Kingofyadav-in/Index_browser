TOR_SOCKS_HOST=127.0.0.1
TOR_SOCKS_PORT=9050
TOR_CONTROL_PORT=9051
TOR_CONTROL_PASSWORD=

CHROME_DRIVER_PATH=
CHROME_BINARY_PATH=

DEFAULT_SEARCH_ENGINE_CLEAR=https://www.google.com/search?q={}
DEFAULT_SEARCH_ENGINE_TOR=https://duckduckgogg42xjoc72x3sjasowoarfbgcmvfimaftt6twagswzczad.onion/?q={}
DEFAULT_HOME_URL_CLEAR=index://newtab/
DEFAULT_HOME_URL_TOR=index://newtab/

# Compatibility switches. Keep disabled unless a specific site requires them.
IGNORE_CERTIFICATE_ERRORS=false
DISABLE_WEB_SECURITY=false

WEB_CACHE_DIR=.index_cache/web
WEB_STORAGE_DIR=.index_cache/storage
WEB_CACHE_SIZE_MB=512

# Onion hardening and diagnostics.
BLOCK_CLEARNET_SUBRESOURCES_ON_ONION=true
LOG_SLOW_ONION_RESOURCES=true
SLOW_ONION_RESOURCE_MS=900
